{
  "name": "plc-sheets",
  "version": "0.1.0",
  "description": "Excel-compatible spreadsheet with inline Modbus PLC communication",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:all": "npm run build && npm run build:main",
    "start": "npm run build:all && electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest run",
    "package": "npm run build:all && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "classic-level": "^1.4.1",
    "downsample": "^1.3.0",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "hyperformula": "^2.7.0",
    "modbus-serial": "^8.0.17",
    "uplot": "^1.6.31",
    "w2ui": "^2.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "build": {
    "appId": "com.plcsheets.app",
    "productName": "PLC-Sheets",
    "copyright": "Copyright © 2026 PLC-Sheets contributors",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "LICENSE",
      "NOTICE.md"
    ],
    "asar": true,
    "fileAssociations": [
      {
        "ext": "xlsx",
        "name": "Excel Workbook",
        "role": "Editor"
      },
      {
        "ext": "xlsm",
        "name": "Excel Macro-Enabled Workbook",
        "role": "Editor"
      },
      {
        "ext": "xls",
        "name": "Excel 97-2003 Workbook",
        "role": "Editor"
      },
      {
        "ext": "csv",
        "name": "CSV (comma-separated values)",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PLC-Sheets"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Office",
      "synopsis": "Spreadsheet with inline Modbus PLC communication"
    }
  }
}
